---
const { currentLocale, url } = Astro;
const pathname = url.pathname;

let switchPath;
if (currentLocale === 'en') {
    // En to Ja
    if (pathname === '/' || pathname.startsWith('/en/')) {
        // / → /ja/, /en/... → /ja/...
        switchPath = pathname === '/' ? '/ja/' : pathname.replace(/^\/en/, '/ja');
    }
} else if (currentLocale === 'ja') {
    // Ja to En
    if (pathname === '/ja/' || pathname.startsWith('/ja/')) {
        // /ja/ → /, /ja/... → /en/...
        switchPath = pathname === '/ja/' ? '/' : pathname.replace(/^\/ja/, '/en');
    }
}
---
<header>
    <div class="header-inner">

        <!-- site name -->
        <div class="site-name">
            IndeXiv
        </div>

        <!-- navigation -->
        <nav class="site-nav" aria-label="navigation">
            <a href={`/${currentLocale}/`}>Home</a>
            <span class="sep">|</span>
            <a href={`/${currentLocale}/about/`}>About</a>
            <span class="sep">|</span>
            <a href={`/${currentLocale}/blog/`}>Blog</a>
        </nav>

        <!-- actions -->
        <div class="header-actions">
            <a href={switchPath} class="language" aria-label="language">
                <i class="fa-solid fa-language"></i>
            </a>
            <a href="/rss.xml" class="RSS" aria-label="RSS Feed">
                <i class="fa-solid fa-rss"></i>
            </a>
        </div>

    </div>
</header>
