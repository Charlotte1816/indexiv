---
interface Crumb {
    label: string;
    href: string;
}

const { items } = Astro.props as { items: Crumb[] };
---

<nav aria-label="Breadcrumb">
    <ol class="breadcrumb">
        {items.map((item, index) => (
        <li>
            {index < items.length - 1 ? (
            <>
                <a href={item.href}>{item.label}</a>
                <span class="separator">›</span>
            </>
            ) : (
            <span aria-current="page">{item.label}</span>
            )}
        </li>
        ))}
    </ol>
</nav>

<style>
.breadcrumb {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.1rem;
    list-style: none;
    padding: 0;
    margin: 1rem 0;
    font-size: 0.9rem;
}

.breadcrumb li {
    display: flex;
    align-items: center;
}

.separator {
    margin: 0 0.5rem;
    color: #888;
}

.breadcrumb a {
    text-decoration: none;
    color: inherit;
}

.breadcrumb a:hover {
    text-decoration: underline;
}
</style>
