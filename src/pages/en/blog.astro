---
import Base from '../../layouts/BaseLayout.astro';

const allPosts = Object.values(import.meta.glob('./posts/*.md', { eager: true }));

const title = "Blog";
const description = "dev news";
const url = "https://indexiv.org/en/blog/";
const type = "website";
const lang = "en";
---
<Base title={title} description={description} url={url} type={type} lang={lang}>
  <p>News</p>
  <ul>
      {allPosts.map((post: any) => <li><a href={post.url}>{post.frontmatter.title} [{post.frontmatter.date}]</a></li>)}
  </ul>
</Base>