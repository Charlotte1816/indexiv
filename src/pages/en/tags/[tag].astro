---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const url = "https://indexiv.org/en/terms/" + Astro.params.tag + "/";
const type = "article";
const lang = "en";

import { getCollection } from 'astro:content';

export async function getStaticPaths() {
    const entries = await getCollection('en');

    // 全タグ抽出
    const tagSet = new Set();

    for (const entry of entries) {
        entry.data.tags?.forEach(tag => tagSet.add(tag));
    }

    return Array.from(tagSet).map(tag => ({
        params: { tag },
        props: { tag }
    }));
}

const { tag } = Astro.props;
const entries = await getCollection('en');

// 該当タグでフィルタ
const filtered = entries.filter(e =>
    e.data.tags?.includes(tag)
);

import Breadcrumb from '../../../components/Breadcrumb.astro';

const crumbs = [
    { label: "Home", href: "/en/" },
    { label: tag, href: `/en/tags/${tag}/` }
];


// ソート
entries.sort((a, b) =>
    a.data.indexKey.localeCompare(b.data.indexKey)
);

// グループ化
const grouped = {};

for (const entry of entries) {
    const letter = entry.data.indexKey[0].toUpperCase();
    if (!grouped[letter]) grouped[letter] = [];
    grouped[letter].push(entry);
}

const letters = Object.keys(grouped).sort();
---

<BaseLayout
    title={`Tag: ${tag}`}
    description={`Entries tagged with ${tag}`}
    url={`https://indexiv.org/en/tags/${tag}/`}
    type={type}
    lang={lang}
>
    <Breadcrumb items={crumbs} />

    {letters.map(letter => (
        <section id={letter}>
        <h2>{letter}</h2>
        <ul>
            {grouped[letter].map(entry => (
            <li>
                <a href={`/en/terms/${entry.slug}/`}>
                {entry.data.title}
                </a>
            </li>
            ))}
        </ul>
        </section>
    ))}
</BaseLayout>
