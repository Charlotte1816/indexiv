---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const url = "https://indexiv.org/ja/terms/" + Astro.params.tag + "/";
const type = "article";
const lang = "ja";

import { getCollection } from 'astro:content';

export async function getStaticPaths() {
    const entries = await getCollection('ja');

    // 全タグ抽出
    const tagSet = new Set();

    for (const entry of entries) {
        entry.data.tags?.forEach(tag => tagSet.add(tag));
    }

    return Array.from(tagSet).map(tag => ({
        params: { tag },
        props: { tag }
    }));
}

const { tag } = Astro.props;
const entries = await getCollection('ja');

// 該当タグでフィルタ
const filtered = entries.filter(e =>
    e.data.tags?.includes(tag)
);

import Breadcrumb from '../../../components/Breadcrumb.astro';

const crumbs = [
    { label: "Home", href: "/" },
    { label: "Ja", href: "/ja/" },
    { label: tag, href: `/ja/tags/${tag}/` }
];

const kana = [
    'あ','い','う','え','お',
    'か','き','く','け','こ',
    'さ','し','す','せ','そ',
    'た','ち','つ','て','と',
    'な','に','ぬ','ね','の',
    'は','ひ','ふ','へ','ほ',
    'ま','み','む','め','も',
    'や','ゆ','よ',
    'ら','り','る','れ','ろ',
    'わ'
];

// locale指定が重要
entries.sort((a, b) =>
    a.data.indexKey.localeCompare(b.data.indexKey)
);

// グループ化
const grouped = {};

for (const entry of entries) {
    const key = entry.data.indexKey;
    if (!grouped[key]) grouped[key] = [];
    grouped[key].push(entry);
}
---

<BaseLayout
    title={`Tag: ${tag}`}
    description={`Entries tagged with ${tag}`}
    url={`https://indexiv.org/ja/tags/${tag}/`}
    type={type}
    lang={lang}
>
    <Breadcrumb items={crumbs} />

    {kana.map(k => (
        grouped[k] && (
        <section id={k}>
            <h2>{k}</h2>
            <ul>
            {grouped[k].map(entry => (
                <li>
                <a href={`/ja/terms/${entry.slug}/`}>
                    {entry.data.title}
                </a>
                </li>
            ))}
            </ul>
        </section>
        )
    ))}
</BaseLayout>
